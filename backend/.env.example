# =============================================================================
# ReRise — шаблон окружения
# Скопируйте в .env и при необходимости поправьте значения:
#   copy .env.example .env
# =============================================================================

# --- Django ---
# Секретный ключ (в проде обязательно свой длинный)
DJANGO_SECRET_KEY=change-me-in-production
# true = отладка; в проде false
DJANGO_DEBUG=true
# Хосты через запятую
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Демо: true = все опубликованные программы открыты в кабинете без тарифа
# Демо-обход тарифов для академии. В production всегда false.
ACADEMY_OPEN_ACCESS=false

# --- PostgreSQL ---
POSTGRES_DB=rerise
POSTGRES_USER=rerise
POSTGRES_PASSWORD=rerise
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Продукт ---
# Базовый URL реферальных ссылок (POST /me/invite-link).
# Итоговая ссылка: {RERISE_REFERRAL_BASE_URL}/{REFERRAL_CODE}
# Прод:  https://your-domain.com/join
# Локально: http://localhost:3020/join
RERISE_REFERRAL_BASE_URL=https://rerise.app/join
# Длина «месяца» активности партнёра после покупки/renew
ACTIVITY_DAYS_PER_MONTH=30
# За сколько дней до конца активности можно оформить продление
RENEWAL_WINDOW_DAYS=7

# --- Оплата (провайдер) ---
# manual  — подтверждение в Django Admin (Confirm Payment), удобно для локалки
# mock    — фейковый payment_url без внешнего API (тесты / фронт без CryptoBot)
# cryptobot — Telegram Crypto Pay API (нужен CRYPTOBOT_API_TOKEN)
PAYMENT_PROVIDER=manual

# Только для PAYMENT_PROVIDER=manual
# Сколько минут висит pending-заказ/инвойс
MANUAL_PAYMENT_TTL_MINUTES=60
# Текст для пользователя; плейсхолдеры: {order_id}, {amount_usd}
MANUAL_PAYMENT_INSTRUCTIONS=Заказ #{order_id} на ${amount_usd}. Оплатите USDT и дождитесь подтверждения администратором.

# --- CryptoBot / Crypto Pay (когда PAYMENT_PROVIDER=cryptobot) ---
# API-токен из @CryptoBot → Crypto Pay → Create App
CRYPTOBOT_API_TOKEN=
# true = testnet (https://testnet-pay.crypt.bot), false = mainnet
CRYPTOBOT_TESTNET=true
# Секретный сегмент URL webhook (не светить публично).
# Полный путь: POST /api/v1/store/webhook/cryptobot/<этот_секрет>
CRYPTOBOT_WEBHOOK_SECRET_PATH=dev-webhook-secret
# Актив инвойса (обычно USDT)
CRYPTOBOT_ASSET=USDT
# TTL инвойса в минутах
CRYPTOBOT_INVOICE_TTL_MINUTES=60
# Кнопка «вернуться» после оплаты; {order_id} подставится автоматически
CRYPTOBOT_PAID_BTN_URL=https://rerise.app/market?order={order_id}

# --- Celery / Redis ---
# Брокер очереди. Пусто = задачи fulfill/sync выполняются синхронно (eager),
# worker/beat не нужны. Пример: redis://127.0.0.1:6379/0
CELERY_BROKER_URL=
# Бэкенд результатов Celery (по умолчанию = CELERY_BROKER_URL)
CELERY_RESULT_BACKEND=
# true/false — принудительно eager; если не задано: eager при пустом BROKER
# CELERY_TASK_ALWAYS_EAGER=true
# Redis для Django cache (replay webhook и т.п.). Пусто = LocMemCache
# Пример: redis://127.0.0.1:6379/1
REDIS_URL=

# --- iBox (AI) ---
# mock — заглушка ответов; openai — реальный API (нужен OPENAI_API_KEY)
IBOX_AI_PROVIDER=mock
OPENAI_API_KEY=
