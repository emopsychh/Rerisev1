# =============================================================================
# ReRise — production Docker env (repo root)
#   cp .env.example .env
#   docker compose up -d --build
#   ./docker/issue-ssl.sh          # after DNS A → this server
# =============================================================================

# --- Host / TLS ---
DOMAIN=systema.site
SSL_EMAIL=admin@systema.site
PUBLIC_HOST=systema.site
HTTP_PORT=80
HTTPS_PORT=443
NEXT_PUBLIC_API_URL=/api/v1

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=systema.site,www.systema.site,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://systema.site,https://www.systema.site
DJANGO_CORS_ALLOWED_ORIGINS=https://systema.site,https://www.systema.site
ACADEMY_OPEN_ACCESS=false

# --- PostgreSQL (compose injects host=postgres) ---
POSTGRES_DB=rerise
POSTGRES_USER=rerise
POSTGRES_PASSWORD=change-me-db-password

# --- Product ---
RERISE_REFERRAL_BASE_URL=https://systema.site/join
ACTIVITY_DAYS_PER_MONTH=30
RENEWAL_WINDOW_DAYS=7

# --- Payments ---
PAYMENT_PROVIDER=manual
MANUAL_PAYMENT_TTL_MINUTES=60
MANUAL_PAYMENT_INSTRUCTIONS=Заказ #{order_id} на ${amount_usd}. Оплатите USDT и дождитесь подтверждения администратором.

CRYPTOBOT_API_TOKEN=
CRYPTOBOT_TESTNET=true
CRYPTOBOT_WEBHOOK_SECRET_PATH=change-me-webhook-secret
CRYPTOBOT_ASSET=USDT
CRYPTOBOT_INVOICE_TTL_MINUTES=60
CRYPTOBOT_PAID_BTN_URL=https://systema.site/market?order={order_id}

# --- First boot only: set true once, then false and recreate api ---
RUN_SEED_DEMO=false

# --- iBox ---
IBOX_AI_PROVIDER=mock
OPENAI_API_KEY=
